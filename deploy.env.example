NODE_ENV=production
PORT=3000

# Shopify app credentials from the Partner Dashboard
SHOPIFY_API_KEY=replace-with-your-api-key
SHOPIFY_API_SECRET=replace-with-your-api-secret

# Must match the scopes declared in shopify.app.toml
SCOPES=write_products,write_metaobjects,write_metaobject_definitions,write_discounts

# Final public HTTPS URL for your deployed app
SHOPIFY_APP_URL=https://your-app-domain.example.com

# Optional, only if you use a custom myshopify domain flow
SHOP_CUSTOM_DOMAIN=

# For a single-instance deployment you can use SQLite:
# DATABASE_URL=file:./prisma/prod.sqlite
# For live stores, prefer a managed Postgres/MySQL database.
DATABASE_URL=postgresql://user:password@host:5432/rufftail_discount_app?schema=public
